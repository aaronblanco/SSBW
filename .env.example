# Puerto HTTP interno del contenedor/aplicación
PORT=3000

# Ejemplo local con Docker compose
# DATABASE_URL="postgresql://ssbw:ssbw@localhost:5433/ssbw?schema=public"

# En producción (DigitalOcean Managed PostgreSQL), reemplazar host/usuario/pass
DATABASE_URL="postgresql://USER:PASSWORD@HOST:25060/ssbw?sslmode=require&schema=public"

# OBLIGATORIO en producción: usar un secreto largo y aleatorio
JWT_SECRET="cambia_este_secreto_en_produccion"

# Lista de orígenes permitidos por CORS (separados por coma)
# Ejemplo con frontend en otro dominio:
# CORS_ORIGINS="https://tu-frontend.ondigitalocean.app"
CORS_ORIGINS=""

# Usuario admin inicial (se crea solo si no existe)
DEFAULT_ADMIN_EMAIL="admin@ssbw.local"
DEFAULT_ADMIN_PASSWORD="cambia_esta_password"

# Si no quieres autoprovisionar admin al arrancar
DISABLE_DEFAULT_ADMIN=false

# Scraping
SCRAPE_MAX_PAGES=4
SCRAPE_HEADLESS=true
