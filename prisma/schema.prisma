generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int      @id @default(autoincrement())
  source    String
  title     String
  price     Float?
  rawPrice  String?
  currency  String   @default("EUR")
  url       String   @unique
  image     String?
  scrapedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([title])
}
