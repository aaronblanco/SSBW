---
const {
	title = 'SSBW - MiauMarket',
	description = 'Catálogo de productos y gatitos locales hecho con Astro.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #0b1020;
		--surface: rgba(17, 24, 39, 0.82);
		--surface-strong: rgba(15, 23, 42, 0.96);
		--line: rgba(255, 255, 255, 0.09);
		--text: #f8fafc;
		--muted: #b6c2d6;
		--accent: #f59e0b;
		--shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		font-family: 'Montserrat', system-ui, sans-serif;
		background:
			radial-gradient(circle at top left, rgba(56, 189, 248, 0.22), transparent 28%),
			radial-gradient(circle at top right, rgba(245, 158, 11, 0.2), transparent 24%),
			linear-gradient(180deg, #050816 0%, var(--bg) 35%, #090d1a 100%);
		color: var(--text);
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	button,
	input,
	select,
	textarea {
		font: inherit;
	}

	::selection {
		background: rgba(245, 158, 11, 0.35);
		color: white;
	}
</style>
